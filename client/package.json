{
  "name": "blesk-client",
  "version": "0.5.4-beta",
  "description": "blesk — приватный десктопный мессенджер. Клиент (Electron + React).",
  "private": true,
  "author": "gotblesk",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "lint": "eslint src/"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.577.0",
    "mediasoup-client": "^3.18.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-easy-crop": "^5.5.6",
    "react-router-dom": "^7.1.0",
    "socket.io-client": "^4.8.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.0.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "fun.blesk.app",
    "productName": "blesk",
    "artifactName": "blesk-Setup-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "gotblesk",
      "repo": "blesk"
    },
    "executableName": "blesk",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico",
      "signAndEditExecutable": true
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "blesk",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "dist/**/*",
      "!dist/win-unpacked",
      "!dist/win-unpacked/**/*",
      "!dist/*.exe",
      "!dist/*.blockmap",
      "!dist/builder-debug.yml",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asar": true,
    "compression": "maximum",
    "extraResources": [
      {
        "from": "public/icon.ico",
        "to": "icon.ico"
      }
    ]
  }
}
