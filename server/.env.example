# blesk server environment variables
PORT=3000
CLIENT_URL=http://localhost:5173
DATABASE_URL=postgresql://user:password@localhost:5432/blesk
JWT_SECRET=your-secret-key-here
JWT_REFRESH_SECRET=your-refresh-secret-here
ADMIN_SECRET=your-admin-secret

# SMTP
SMTP_HOST=smtp.beget.com
SMTP_PORT=465
SMTP_USER=noreply@blesk.fun
SMTP_PASS=your-smtp-password

# Media server
MEDIASOUP_ANNOUNCED_IP=83.222.16.169

# TURN server (optional — for NAT traversal)
TURN_URL=turn:83.222.16.169:3478
TURN_USERNAME=blesk
TURN_CREDENTIAL=your-turn-password

# ClamAV (optional)
CLAMAV_ENABLED=false
CLAMAV_SOCKET=/var/run/clamav/clamd.ctl
