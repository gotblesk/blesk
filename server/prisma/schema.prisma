generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  tag          String   // #1234
  phone        String?  @unique
  passwordHash String   @map("password_hash")
  publicKey    String?  @map("public_key")
  signingKey   String?  @map("signing_key") // Ed25519 public key (blesk Shield)
  avatar       String?
  bio          String?
  status       String?  @default("offline")
  customStatus String?  @map("custom_status")
  bleskCoins   Int      @default(0) @map("blesk_coins")
  email         String?  @unique
  emailVerified Boolean  @default(false) @map("email_verified")
  hue          Int      @default(0) // 0-360, цвет аватара
  lastSeenAt   DateTime? @map("last_seen_at")
  showLastSeen Boolean   @default(true) @map("show_last_seen")
  createdAt    DateTime @default(now()) @map("created_at")

  role          String    @default("user") // user, moderator, admin
  banned        Boolean   @default(false)
  bannedAt      DateTime? @map("banned_at")
  bannedReason  String?   @map("banned_reason")
  bannedBy      String?   @map("banned_by")
  verifiedLevel Int       @default(0) @map("verified_level") // 0=none, 1=email, 2=phone, 3=official

  twoFactorEnabled  Boolean  @default(false) @map("two_factor_enabled")
  twoFactorSecret   String?  @map("two_factor_secret")

  sentMessages           Message[]
  ownedRooms             Room[]            @relation("RoomOwner")
  participations         RoomParticipant[]
  notifications          Notification[]    @relation("UserNotifications")
  sentNotifications      Notification[]    @relation("NotificationSender")
  sentFriendRequests     FriendRequest[]   @relation("FriendRequestSender")
  receivedFriendRequests FriendRequest[]   @relation("FriendRequestReceiver")
  channelSubscriptions   ChannelSubscriber[] @relation("UserSubscriptions")
  userTags               UserTag[]         @relation("UserTags")
  grantedTags            UserTag[]         @relation("TagGranter")
  auditLogs              AuditLog[]
  reports                Report[]          @relation("ReportReporter")
  resolvedReports        Report[]          @relation("ReportResolver")
  feedbacks              Feedback[]
  preKeyBundle           PreKeyBundle?
  blockedUsers           BlockedUser[] @relation("blocker")
  blockedByUsers         BlockedUser[] @relation("blocked")
  reactions              MessageReaction[]

  @@map("users")
}

// ═══ blesk Shield — Pre-Key Infrastructure ═══

model PreKeyBundle {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  signingKey      String   @map("signing_key")
  signedPreKey    String   @map("signed_pre_key")
  signedPreKeySig String   @map("signed_pre_key_sig")
  signedPreKeyId  Int      @map("signed_pre_key_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  oneTimePreKeys  OneTimePreKey[]

  @@map("pre_key_bundles")
}

model OneTimePreKey {
  id        String   @id @default(uuid())
  bundleId  String   @map("bundle_id")
  keyId     Int      @map("key_id")
  publicKey String   @map("public_key")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  bundle    PreKeyBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  @@unique([bundleId, keyId])
  @@index([bundleId, used])
  @@map("one_time_pre_keys")
}

model KeyTransparencyLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  keyType   String   @map("key_type")
  publicKey String   @map("public_key")
  prevHash  String   @map("prev_hash")
  signature String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("key_transparency_log")
}

model Room {
  id       String    @id @default(uuid())
  name     String
  type     String    @default("chat") // chat, group, channel, voice
  avatar   String?
  ownerId  String    @map("owner_id")
  owner    User      @relation("RoomOwner", fields: [ownerId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  messages     Message[]
  participants RoomParticipant[]
  channelMeta  ChannelMeta?
  subscribers  ChannelSubscriber[] @relation("ChannelSubscribers")

  @@index([type])
  @@index([ownerId])
  @@index([type, ownerId])
  @@map("rooms")
}

model Message {
  id        String   @id @default(uuid())
  roomId    String   @map("room_id")
  room      Room     @relation(fields: [roomId], references: [id])
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  text      String   @default("")
  encrypted Boolean  @default(false)
  type      String   @default("text") // text, media, system
  pinned    Boolean  @default(false)
  replyToId String?  @map("reply_to_id")
  replyTo   Message? @relation("MessageReplies", fields: [replyToId], references: [id])
  replies   Message[] @relation("MessageReplies")
  attachments Attachment[]
  reactions   MessageReaction[]
  createdAt DateTime @default(now()) @map("created_at")

  @@index([roomId, createdAt])
  @@map("messages")
}

model Attachment {
  id           String   @id @default(uuid())
  messageId    String   @map("message_id")
  message      Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  filename     String
  storedName   String   @map("stored_name")
  mimeType     String   @map("mime_type")
  size         Int
  url          String
  thumbnailUrl String?  @map("thumbnail_url")
  width        Int?
  height       Int?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([messageId])
  @@map("attachments")
}

model RoomParticipant {
  id         String   @id @default(uuid())
  roomId     String   @map("room_id")
  userId     String   @map("user_id")
  role       String   @default("member") // owner, admin, member
  joinedAt   DateTime @default(now()) @map("joined_at")
  lastReadAt DateTime @default(now()) @map("last_read_at")
  isMuted    Boolean   @default(false) @map("is_muted")
  mutedUntil DateTime? @map("muted_until")
  room       Room     @relation(fields: [roomId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@index([userId])
  @@map("room_participants")
}

model Notification {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  type       String   // mention, message, friend_request, friend_accepted, system
  title      String
  body       String   @default("")
  fromUserId String?  @map("from_user_id")
  roomId     String?  @map("room_id")
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User  @relation("UserNotifications", fields: [userId], references: [id])
  fromUser User? @relation("NotificationSender", fields: [fromUserId], references: [id])

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model FriendRequest {
  id         String   @id @default(uuid())
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")
  status     String   @default("pending") // pending, accepted, declined
  createdAt  DateTime @default(now()) @map("created_at")

  sender   User @relation("FriendRequestSender", fields: [senderId], references: [id])
  receiver User @relation("FriendRequestReceiver", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@index([senderId])
  @@map("friend_requests")
}

model EmailCode {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, code])
  @@index([expiresAt])
  @@map("email_codes")
}

// [CRIT-2] Refresh токены — для ревокации и управления сессиями
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model Feedback {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  type       String   // bug, suggestion, question
  text       String
  appVersion String   @map("app_version")
  osInfo     String   @map("os_info")
  status     String   @default("new") // new, reviewed, resolved
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([status])
  @@map("feedback")
}

model ChannelMeta {
  id              String   @id @default(uuid())
  roomId          String   @unique @map("room_id")
  room            Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  description     String   @default("")
  category        String   @default("other")
  isPublic        Boolean  @default(true) @map("is_public")
  subscriberCount Int      @default(0) @map("subscriber_count")
  postCount       Int      @default(0) @map("post_count")
  avatarUrl       String?  @map("avatar_url")
  coverUrl        String?  @map("cover_url")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("channel_meta")
}

model ChannelSubscriber {
  id           String   @id @default(uuid())
  channelId    String   @map("channel_id")
  channel      Room     @relation("ChannelSubscribers", fields: [channelId], references: [id], onDelete: Cascade)
  userId       String   @map("user_id")
  user         User     @relation("UserSubscriptions", fields: [userId], references: [id])
  subscribedAt DateTime @default(now()) @map("subscribed_at")

  @@unique([channelId, userId])
  @@index([channelId])
  @@index([userId])
  @@map("channel_subscribers")
}

model Tag {
  id          String    @id @default(uuid())
  name        String    @unique
  color       String    @default("#c8ff00")
  type        String    @default("system") // system, achievement, seasonal, community
  rarity      String    @default("common") // common, uncommon, rare, epic, legendary
  description String    @default("")
  icon        String?   // lucide icon name
  createdAt   DateTime  @default(now()) @map("created_at")

  userTags    UserTag[]

  @@map("tags")
}

model UserTag {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tagId     String   @map("tag_id")
  grantedBy String?  @map("granted_by")
  grantedAt DateTime @default(now()) @map("granted_at")

  user    User  @relation("UserTags", fields: [userId], references: [id])
  tag     Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  granter User? @relation("TagGranter", fields: [grantedBy], references: [id])

  @@unique([userId, tagId])
  @@index([userId])
  @@map("user_tags")
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String   @map("admin_id")
  action     String   // user.ban, user.unban, user.edit, tag.create, tag.grant, message.delete, etc.
  targetType String   @map("target_type") // user, tag, message, channel, report, feedback
  targetId   String   @map("target_id")
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Report {
  id         String   @id @default(uuid())
  reporterId String   @map("reporter_id")
  targetType String   @map("target_type") // user, message, channel
  targetId   String   @map("target_id")
  category   String   // spam, harassment, nsfw, other
  text       String   @default("")
  status     String   @default("new") // new, reviewed, resolved, rejected
  resolvedBy String?  @map("resolved_by")
  createdAt  DateTime @default(now()) @map("created_at")

  reporter User  @relation("ReportReporter", fields: [reporterId], references: [id])
  resolver User? @relation("ReportResolver", fields: [resolvedBy], references: [id])

  @@index([status])
  @@index([createdAt])
  @@map("reports")
}

model BlockedUser {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User @relation("blocker", fields: [userId], references: [id])
  blocked User @relation("blocked", fields: [blockedId], references: [id])

  @@unique([userId, blockedId])
  @@index([userId])
  @@index([blockedId])
  @@map("blocked_users")
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("message_reactions")
}
